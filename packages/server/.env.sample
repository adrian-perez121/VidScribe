# Prisma Postgres connection string (written by `prisma postgres link`).
DATABASE_URL=""

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL=""

# Anthropic API key — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=""
# Deepgram — speech-to-text for voice notes (https://console.deepgram.com).
DEEPGRAM_API_KEY=""
# Set to "true" to skip the real Deepgram call and return a mock transcript
# (useful for local demos when there's no network access or API key).
MOCK_DEEPGRAM=""
# Browserbase — headless browser cloud (https://www.browserbase.com).
# Dashboard → Settings for the API key and Project ID.
BROWSERBASE_API_KEY=""
BROWSERBASE_PROJECT_ID=""
# Set to "true" to skip the real Browserbase/Gemini research call and return a
# mock summary (useful for local demos when there's no network access or keys).
MOCK_BROWSERBASE=""

# LLM key Stagehand uses to drive act()/extract(). Set the one that matches the
# `model` in lib/stagehand.ts:
#   model: "google/gemini-3-flash-preview" -> GEMINI_API_KEY
#   model: "claude-sonnet-4-6"             -> ANTHROPIC_API_KEY
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
